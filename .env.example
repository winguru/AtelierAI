# Core runtime paths
DATABASE_URL=sqlite:///app/image_db.sqlite
IMAGE_LIBRARY_PATH=app/image_library
IMAGE_RESOURCES_PATH=app/image_resources

# Startup behavior
ATELIER_HOST=0.0.0.0
ATELIER_PORT=8000
ATELIER_RELOAD=1
ATELIER_SUPPRESS_STATUS_GET_LOGS=1
ATELIER_DISABLE_ACCESS_LOG=0

# Optional dev/runtime overrides
# ATELIER_APP_ROOT=/absolute/path/to/repo/app
# ALLOW_SCHEMA_RESET=false

# Optional external integrations
# CIVITAI_BASE_DOMAIN=civitai.red
# CIVITAI_API_KEY=
# CIVITAI_USERNAME=
# CIVITAI_PASSWORD=
# Optional OAuth browser profile overrides:
# CIVITAI_CHROME_USER_DATA_DIR=/Users/<you>/Library/Application Support/Google/Chrome
# CIVITAI_CHROME_PROFILE_DIRECTORY=Default
# ATELIER_COMFYUI_BASE_URL=
