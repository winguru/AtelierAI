# Project-scoped Python path for VS Code debug/test execution
PYTHONPATH=app/src:app/backend:app/dev

# Core runtime paths
DATABASE_URL=sqlite:///app/image_db.sqlite
IMAGE_LIBRARY_PATH=app/image_library
IMAGE_RESOURCES_PATH=app/image_resources

# Startup behavior
ATELIER_HOST=0.0.0.0
ATELIER_PORT=8000
ATELIER_RELOAD=1
ATELIER_SUPPRESS_STATUS_GET_LOGS=1
ATELIER_DISABLE_ACCESS_LOG=0

# Optional dev/runtime overrides
# ATELIER_APP_ROOT=/absolute/path/to/repo/app
# ALLOW_SCHEMA_RESET=false

# Optional external integrations
#.   CivitAI domain — use "civitai.red" for full content access (PG through XXX).
#.   Set to "civitai.com" for the sanitized/filtered site.
CIVITAI_BASE_DOMAIN="civitai.red"
# CIVITAI_API_KEY=
#.   Meilisearch key is required for CivitAI search functionality, but not for 
#.   general API access.  Find the key 
# CIVITAI_MEILISEARCH_KEY=
# CIVITAI_USERNAME=
# CIVITAI_PASSWORD=
CIVITAI_STATUS_INTERVAL=60
CIVITAI_TARGET_TPM=180
CIVITAI_MAX_BURST_SECONDS=30

# Optional OAuth browser profile overrides:
# CIVITAI_CHROME_USER_DATA_DIR=/Users/<you>/Library/Application Support/Google/Chrome
# CIVITAI_CHROME_PROFILE_DIRECTORY=Default
ATELIER_COMFYUI_BASE_URL="http://localhost:8188"
